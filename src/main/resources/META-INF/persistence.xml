<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="2.2"
             xmlns="http://xmlns.jcp.org/xml/ns/persistence"
             xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence http://xmlns.jcp.org/xml/ns/persistence/persistence_2_2.xsd">
    <persistence-unit name="BuildWeek4">
        <class>emanuelepiemonte.entities.PuntoDiEmissione</class>
        <class>emanuelepiemonte.entities.DistributoreAutomatico</class>
        <class>emanuelepiemonte.entities.RivenditoreAutorizzato</class>
        <class>emanuelepiemonte.entities.Tessera</class>
        <class>emanuelepiemonte.entities.Biglietto</class>
        <class>emanuelepiemonte.entities.Manutenzione</class>
        <class>emanuelepiemonte.entities.Abbonamento</class>
        <class>emanuelepiemonte.entities.Mezzo</class>
        <class>emanuelepiemonte.entities.Tratta</class>
        <class>emanuelepiemonte.entities.Utente</class>
        <class>emanuelepiemonte.entities.PercorrenzaTratta</class>
        <properties>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/BuildWeek4"/>
            <property name="jakarta.persistence.jdbc.user" value="postgres"/>
            <property name="jakarta.persistence.jdbc.password" value="1234"/>
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
        </properties>
    </persistence-unit>
</persistence>
